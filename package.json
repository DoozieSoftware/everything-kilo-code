{
  "name": "ekc-universal",
  "version": "1.0.0",
  "description": "Complete collection of battle-tested Kilo CLI configs — agents, skills, commands, rules, and MCP configurations for the Kilo AI coding assistant",
  "keywords": [
    "kilo",
    "kilo-cli",
    "ai",
    "agents",
    "skills",
    "mcp",
    "rules",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices",
    "laravel",
    "php",
    "typescript",
    "vue",
    "react",
    "python",
    "go",
    "rust",
    "java"
  ],
  "author": {
    "name": "DoozieSoftware",
    "url": "https://github.com/DoozieSoftware"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoozieSoftware/everything-kilo-code.git"
  },
  "homepage": "https://github.com/DoozieSoftware/everything-kilo-code#readme",
  "bugs": {
    "url": "https://github.com/DoozieSoftware/everything-kilo-code/issues"
  },
  "files": [
    ".kilo/",
    "agents/",
    "commands/",
    "contexts/",
    "examples/",
    "manifests/",
    "mcp-configs/",
    "rules/",
    "schemas/",
    "scripts/",
    "skills/",
    "AGENTS.md",
    "kilo.jsonc",
    "install.sh",
    "install.ps1"
  ],
  "bin": {
    "ekc": "scripts/ecc.js",
    "ekc-install": "scripts/install-apply.js"
  },
  "scripts": {
    "postinstall": "echo '\\n  ekc-universal installed!\\n  Run: ./install.sh --target kilo\\n  Docs: https://github.com/DoozieSoftware/everything-kilo-code\\n'",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules",
    "test": "node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-install-manifests.js && node scripts/ci/validate-no-personal-paths.js && node scripts/ci/catalog.js --text && node tests/run-all.js",
    "coverage": "c8 --all --include=\"scripts/**/*.js\" --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --reporter=text --reporter=lcov node tests/run-all.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "ajv": "^8.18.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "c8": "^10.1.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}
